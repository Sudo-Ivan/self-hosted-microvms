DESCRIPTION="Self-hosted push notification server (Gotify)"
MEM_MIB=256
VCPU_COUNT=1
DATA_SIZE_MIB=1024
ROOTFS_SIZE_MIB=1024
PORT_FORWARDS=8080:80
HEALTH_PATH=/
HEALTH_PORT=8080
PACKAGES="ca-certificates curl unzip"
TAGS=notify
DATA_HINT=/data/gotify
NOTES="Default admin password is in /data/gotify/admin.pass"
