DESCRIPTION="qBittorrent Web UI (headless)"
MEM_MIB=512
VCPU_COUNT=1
DATA_SIZE_MIB=8192
ROOTFS_SIZE_MIB=1024
PORT_FORWARDS=8080:8080
HEALTH_PATH=/
HEALTH_PORT=8080
PACKAGES="ca-certificates qbittorrent-nox"
TAGS=torrent
DATA_HINT=/data/qbittorrent
NOTES="Default Web UI login is often admin/adminadmin until changed."
