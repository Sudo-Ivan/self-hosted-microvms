DESCRIPTION="Self-hosted Git service (Gitea)"
MEM_MIB=512
VCPU_COUNT=1
DATA_SIZE_MIB=4096
ROOTFS_SIZE_MIB=1024
PORT_FORWARDS=3000:3000
HEALTH_PATH=/
HEALTH_PORT=3000
PACKAGES="ca-certificates curl git bash sqlite"
TAGS=git,dev
DATA_HINT=/data/gitea
NOTES="Complete setup in the web UI on first visit."
