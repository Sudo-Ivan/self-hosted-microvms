DESCRIPTION="Serve pages and files over the Reticulum network"
MEM_MIB=256
VCPU_COUNT=1
DATA_SIZE_MIB=1024
ROOTFS_SIZE_MIB=1536
PORT_FORWARDS=4242:4242
PACKAGES="ca-certificates curl python3 py3-pip py3-cryptography"
TAGS=mesh,reticulum
DATA_HINT="/data/rns-page-node and /data/reticulum"
NOTES="Drop-in page/file node for RNS. Edit /data/rns-page-node/config and pages after first boot. Upstream: https://github.com/Quad4-Software/rns-page-node"
