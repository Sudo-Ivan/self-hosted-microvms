# Starter Reticulum config for rns-page-node in a microVM.
# Edit /data/reticulum/config after first boot as needed.
# Docs: https://reticulum.network/manual/using.html

[reticulum]
  enable_transport = Yes
  share_instance = Yes

[logging]
  loglevel = 4

[interfaces]

  [[Default Interface]]
    type = AutoInterface
    enabled = yes

  [[TCP Server Interface]]
    type = TCPServerInterface
    enabled = yes
    listen_ip = 0.0.0.0
    listen_port = 4242
