DESCRIPTION="Open-source Tailscale control server (Headscale)"
MEM_MIB=256
VCPU_COUNT=1
DATA_SIZE_MIB=1024
ROOTFS_SIZE_MIB=1024
PORT_FORWARDS=8080:8080
HEALTH_PATH=/health
HEALTH_PORT=8080
PACKAGES="ca-certificates curl"
TAGS=vpn,network
DATA_HINT=/data/headscale
NOTES="Set server_url in /data/headscale/config.yaml to your public URL."
