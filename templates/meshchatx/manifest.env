DESCRIPTION="MeshChatX headless Reticulum client (web UI)"
MEM_MIB=1024
VCPU_COUNT=2
DATA_SIZE_MIB=4096
ROOTFS_SIZE_MIB=4096
PORT_FORWARDS=8000:8000,4242:4242
HEALTH_PATH=/
HEALTH_PORT=8000
HEALTH_SCHEME=https
PACKAGES="ca-certificates curl python3 py3-pip python3-dev gcc g++ musl-dev libffi-dev openssl-dev linux-headers py3-cryptography opus-dev opusfile"
TAGS=mesh,reticulum
DATA_HINT="/data/meshchatx and /data/reticulum"
NOTES="First boot installs Python deps and patches LXST. Prefer recreate after template changes."
HEALTH_WAIT_SECS=300
