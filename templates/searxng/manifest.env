DESCRIPTION="Privacy-respecting metasearch engine (SearXNG)"
MEM_MIB=512
VCPU_COUNT=1
DATA_SIZE_MIB=1024
ROOTFS_SIZE_MIB=3072
PORT_FORWARDS=8888:8888
HEALTH_PATH=/
HEALTH_PORT=8888
PACKAGES="ca-certificates curl git python3 py3-pip python3-dev gcc g++ musl-dev libffi-dev openssl-dev libxslt-dev libxml2-dev zlib-dev"
TAGS=search
DATA_HINT=/data/searxng
NOTES="First boot clones git and builds a venv. Needs outbound HTTPS."
HEALTH_WAIT_SECS=300
