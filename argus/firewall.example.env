# Per-instance Argus firewall policy.
# Copy defaults from templates/<template>/firewall.env when present.
#
# Port specs use proto/port form:
#   tcp/443
#   udp/53
#   tcp/all
#
# Multiple values are comma separated.

# Outbound allow list (used fully when ARGUS_DEFAULT_EGRESS=deny)
EGRESS_ALLOW=

# Outbound deny list (always enforced)
EGRESS_DENY=

# Other instance names or IPs this guest may reach on the bridge
ALLOW_PEERS=

# Extra published ports beyond PORT_FORWARDS (proto/port)
INGRESS_EXTRA=
