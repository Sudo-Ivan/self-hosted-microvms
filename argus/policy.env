# Global Argus policy. Copy to argus/policy.env to override.
# Argus (Argos Panoptes) is the all-seeing guardian of guest traffic.
# Per-instance rules live in instances/<name>/firewall.env

# 1 enable, 0 fall back to simple iptables helpers
ARGUS_ENABLED=1

# Guest outbound internet traffic when no EGRESS_ALLOW match exists
# allow = open egress (still honor EGRESS_DENY and inter-vm policy)
# deny  = only destinations listed in each instance EGRESS_ALLOW
ARGUS_DEFAULT_EGRESS=allow

# Guest to guest traffic on the bridge
# deny = only ALLOW_PEERS paths
# allow = all guests may talk to each other
ARGUS_INTER_VM=deny

# Log dropped packets to the kernel log with argus-drop* prefixes
ARGUS_LOG_DROPS=1

# Permit guests to query external DNS resolvers directly
# Keep 0 when ARGUS_DNS_FORCE=1 so lookups go through Argus
ARGUS_ALLOW_DNS_EGRESS=0

# Permit guests to reach the bridge gateway address on the host
ARGUS_ALLOW_GATEWAY=1

# DNS resolver and blocklists (requires dnsmasq on the host)
ARGUS_DNS_ENABLED=1

# Redirect all guest DNS (tcp/udp 53) to the gateway resolver
ARGUS_DNS_FORCE=1

# Upstream resolvers used after blocklist checks
ARGUS_DNS_UPSTREAM=1.1.1.1,9.9.9.9

# Comma-separated remote blocklist URLs (hosts or domain lists)
# Empty uses the built-in StevenBlack hosts list
ARGUS_DNS_BLOCKLIST_URLS=

# Refetch remote lists on every apply (0 = use cache until dns-update)
ARGUS_DNS_UPDATE_ON_APPLY=0

# Log DNS queries to shared/argus-dns/dnsmasq.log (needed for domain visibility)
ARGUS_DNS_LOG_QUERIES=1

# How many recent DNS rows to show in status/queries
ARGUS_DNS_QUERY_LINES=40
