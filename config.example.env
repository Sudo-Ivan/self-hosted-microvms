# Copy to config.env and adjust for your host.
# No secrets belong in this file.

# Firecracker binary name or absolute path
FIRECRACKER_BIN=firecracker

# Guest kernel series prefix matched against Firecracker CI artifacts
KERNEL_SERIES=6.1

# Optional absolute paths (defaults live under shared/)
# KERNEL_PATH=
# BASE_ROOTFS_PATH=

# Alpine branch and release used for the base rootfs
ALPINE_VERSION=3.21
ALPINE_RELEASE=3.21.3

# Shared private network for guests
BRIDGE_NAME=fcbr0
SUBNET_PREFIX=10.100.0
GATEWAY_IP=10.100.0.1
GUEST_PREFIX=24
DNS=1.1.1.1

# Default guest size when a template omits MEM_MIB / VCPU_COUNT
# (template manifest and --profile / MEM_MIB= still win)
DEFAULT_MEM_MIB=512
DEFAULT_VCPU_COUNT=1

# Default disk sizes in MiB for new instances / base image
BASE_ROOTFS_SIZE_MIB=1024
DEFAULT_DATA_SIZE_MIB=2048

# Optional default resource profile for create/up when --profile is omitted
# (small|default|media|db|proxy or a file under profiles/)
# DEFAULT_PROFILE=

# Start behavior
# DETACH=1 runs Firecracker in the background (default)
# SETUP_NET=1 creates TAP, applies Argus or port forwards (default)
DETACH=1
SETUP_NET=1

# Root helper override when both doas and sudo exist (doas|sudo|/path/to/helper)
# MVM_ROOT_CMD=

# Argus central firewall and DNS (1 = nftables policy on the host bridge)
ARGUS_ENABLED=1

# Apply Argus automatically on every guest start (recommended)
ARGUS_AUTO_APPLY=1

# Optional path to Argus policy (default: argus/policy.env)
# ARGUS_POLICY_FILE=

# Keep this many data backups per instance
BACKUP_KEEP=5

# Optional backups directory (default: shared/backups)
# BACKUPS_DIR=

# Watchdog health probe settings
WATCHDOG_INTERVAL=30
WATCHDOG_FAILURES=3

# Optional path to the secrets CLI (default: .tools/mvmsec)
# MVMSEC_BIN=

# Passphrase for passphrase-wrapped identity (prefer a root-only file)
# MVM_SECRETS_PASSPHRASE=
# MVM_SECRETS_PASSPHRASE_FILE=
